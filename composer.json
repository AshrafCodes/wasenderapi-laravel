{
    "name": "ashraf/wasenderapi-laravel",
    "description": "Laravel package for WasenderAPI WhatsApp sessions, messages, contacts, groups, channels, uploads, and webhooks.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ashraf\\WasenderApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ashraf\\WasenderApi\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ashraf\\WasenderApi\\WasenderApiServiceProvider"
            ],
            "aliases": {
                "WasenderApi": "Ashraf\\WasenderApi\\Facades\\WasenderApi"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
